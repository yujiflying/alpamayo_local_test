      "source": [
        "# Alpamayo 1.5: Local Offline Inference Demo\n",
        "\n",
        "This notebook runs Alpamayo 1.5 on a local offline clip directory, shows all sampled images used for inference, and performs extended diagnostics. It also applies the confirmed evaluation-side GT frame correction (`-90°`) so that GT future is compared in the same `+x-forward` convention as the model output."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "offline-local-imports",
      "metadata": {},
      "outputs": [],
      "source": [
        "import os\n",
        "import sys\n",
        "from pathlib import Path\n",
        "\n",
        "repo_root = Path.cwd().resolve().parent\n",
        "src_path = repo_root / 'src'\n",
        "if str(src_path) not in sys.path:\n",
        "    sys.path.insert(0, str(src_path))\n",
        "\n",
        "print('cwd =', Path.cwd().resolve())\n",
        "print('repo_root =', repo_root)\n",
        "print('src_path =', src_path)\n",
        "print('src exists =', src_path.exists())\n",
        "print('PYTHONPATH =', os.environ.get('PYTHONPATH'))\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "import torch\n",
        "from transformers import BitsAndBytesConfig\n",
